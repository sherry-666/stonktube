# MongoDB Atlas SRV connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/stonktube?retryWrites=true&w=majority

# Redis (Railway plugin injects this in prod; use docker-compose locally)
REDIS_URL=redis://localhost:6379

# Google AI Studio — used for transcription fallback (audio) + video analysis
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# YouTube Data API v3 — used for channel discovery
# Enable at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=AIza...

# Google Cloud Translation API — used for zh/ko UI content translation
# Enable "Cloud Translation API" in the same Google Cloud project as YOUTUBE_API_KEY
# Then create (or reuse) an API key with Translation API permission
GOOGLE_TRANSLATE_API_KEY=AIza...

# Market data — Financial Modeling Prep (free tier: 250 req/day)
# Get your key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=...

# API server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Admin token (guards /api/admin/* in production)
ADMIN_TOKEN=change-me-in-production
