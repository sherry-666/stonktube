# MongoDB Atlas SRV connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/stonktube?retryWrites=true&w=majority

# Redis (Railway plugin injects this in prod; use docker-compose locally)
REDIS_URL=redis://localhost:6379

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API v3
YOUTUBE_API_KEY=AIza...

# Market data — Financial Modeling Prep (default) or Twelve Data
MARKET_DATA_PROVIDER=fmp
FMP_API_KEY=...
TWELVE_DATA_API_KEY=...

# Transcription fallback (pick one)
TRANSCRIPTION_PROVIDER=openai   # openai | deepgram | assemblyai
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...

# API server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Admin token (guards /api/admin/* in production)
ADMIN_TOKEN=change-me-in-production
